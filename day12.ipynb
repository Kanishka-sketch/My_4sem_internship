   "source": [
    "Transpose and Concatenation"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "9dda57ec",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[[ 1  7]\n",
      " [ 2  8]\n",
      " [ 3  9]\n",
      " [ 4 10]]\n",
      "[ 1  2  3  4  7  8  9 10]\n"
     ]
    }
   ],
   "source": [
    "import numpy as np \n",
    "#For single dim, axis= 0 , no 1\n",
    "\n",
    "a = np.array([1,2,3,4])\n",
    "b = np.array([7,8,9,10])\n",
    " \n",
    "res1 = np.transpose((a,b))\n",
    "\n",
    "print(res1)\n",
    "res = np.concatenate((a,b) , axis = 0)\n",
    "\n",
    "print(res)\n",
    "\n"
   ]
  }
 ],
